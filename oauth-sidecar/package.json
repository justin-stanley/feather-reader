{
  "name": "featherreader-oauth-sidecar",
  "version": "0.1.0",
  "private": true,
  "description": "atproto OAuth confidential-client sidecar for FeatherReader — owns the OAuth handshake (PAR/PKCE/DPoP/token-refresh) so the Rust server never touches it. Exposes login/callback + an internal shared-secret-guarded authed com.atproto.repo.* API.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=24 <27"
  },
  "bin": {
    "featherreader-oauth-sidecar": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src test --max-warnings 0",
    "lint:fix": "oxlint src test --fix",
    "format:check": "prettier --check \".oxlintrc.json\" \".prettierrc.json\"",
    "format:write": "prettier --write .",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js"
  },
  "dependencies": {
    "@atproto/api": "^0.20.30",
    "@atproto/jwk-jose": "^0.2.4",
    "@atproto/oauth-client-node": "^0.4.9",
    "@fastify/rate-limit": "^11.1.0",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "oxlint": "^1.74.0",
    "prettier": "3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^7.0.0"
  }
}
